# Unified environment template for Docker and Docker Compose stacks
# Copy this file to .env and adjust values for your project.
# Never commit real secrets.

######################################################
## Global ############################################
######################################################
PROJECT_NAME=platform-kit # Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=Platform Engineering Kit # Human-readable project name used in UI templates
APP_ENV=development # Runtime profile: development or production
IMAGE_NAME=your-org/your-app # Default image repository/name for app builds
IMAGE_VERSION=1.0.0 # Default image tag; use dev in local iterations
CONTAINER_NAME=your-app # Deterministic container name for local stacks
VOLUME_NAME=app-data # Global volume name used by compose volumes.*.name
TZ=UTC # Container timezone
LANG=C.UTF-8 # Locale

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=tools # Network name used by compose networks.network.name
NETWORK_DRIVER=bridge # Network driver used by compose networks.network.driver
NETWORK_MTU=1500 # MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # compose driver_opts: bridge.enable_ip_masquerade
NETWORK_ENABLE_ICC=true # compose driver_opts: bridge.enable_icc
NETWORK_DOMAIN=localhost # Base domain used by reverse proxy/routes

######################################################
## App ###############################################
######################################################
APP_PORT=8080 # App service port published by compose
APP_METRICS_PORT=9090 # Optional metrics endpoint port
APP_UID=10001 # Runtime UID used by Dockerfile and compose user mapping
APP_GID=10001 # Runtime GID used by Dockerfile and compose user mapping

######################################################
## Jenkins ###########################################
######################################################
JENKINS_ADMIN_USER=admin # Jenkins admin username
JENKINS_ADMIN_PASSWORD=change-me # Jenkins admin password placeholder

######################################################
## Keycloak ##########################################
######################################################
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:24.0 # Keycloak base image override
KEYCLOAK_ADMIN=admin # Keycloak admin username
KEYCLOAK_ADMIN_PASSWORD=change-me # Keycloak admin password placeholder

######################################################
## Nginx #############################################
######################################################
NGINX_IMAGE=nginx:1.27-alpine # Nginx image override
NGINX_HTTP_PORT=80 # HTTP public port
NGINX_HTTPS_PORT=443 # HTTPS public port

######################################################
## Portainer #########################################
######################################################
PORTAINER_IMAGE=portainer/portainer-ce:2.19.4 # Portainer image override
PORTAINER_PORT=9443 # Portainer HTTPS port
PORTAINER_ADMIN_PASSWORD=change-me # Portainer admin password placeholder
PORTAINER_HASHED_PASSWORD=replace-with-bcrypt-hash # Bcrypt hash for bootstrap command flags

######################################################
## Profile Examples ##################################
######################################################
# Development example overrides:
# APP_ENV=development
# IMAGE_VERSION=dev
# NETWORK_DOMAIN=localhost
# JENKINS_ADMIN_PASSWORD=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# PORTAINER_ADMIN_PASSWORD=admin
#
# Production example overrides:
# APP_ENV=production
# IMAGE_VERSION=1.0.0
# NETWORK_DOMAIN=platform.example.com
# JENKINS_ADMIN_PASSWORD=replace-me-strong
# KEYCLOAK_ADMIN_PASSWORD=replace-me-strong
# PORTAINER_ADMIN_PASSWORD=replace-me-strong
# PORTAINER_HASHED_PASSWORD=replace-with-bcrypt-hash
