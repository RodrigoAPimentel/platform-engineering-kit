######################################################
## Global ############################################
######################################################
PROJECT_NAME=n8n # Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=N8N # Human-readable project name used in UI templates
APP_ENV=development # Runtime profile: development or production
IMAGE_NAME=n8nio/n8n # Default image repository/name for app builds
IMAGE_VERSION=2.11.4 # Default image tag; use dev in local iterations
CONTAINER_NAME=n8n # Deterministic container name for local stacks
VOLUME_NAME=${PROJECT_NAME}-data # Global volume name used by compose volumes.*.name
TZ=America/Sao_Paulo # Container timezone
LANG=C.UTF-8 # Locale

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=custom-network # Network name used by compose networks.network.name
NETWORK_DRIVER=bridge # Network driver used by compose networks.network.driver
NETWORK_MTU=1500 # MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # compose driver_opts: bridge.enable_ip_masquerade
NETWORK_ENABLE_ICC=true # compose driver_opts: bridge.enable_icc
NETWORK_DOMAIN=192.168.99.21 # Base domain used by reverse proxy/routes

######################################################
## App ###############################################
######################################################
APP_PORT=5678 # App service port published by compose
APP_UID=1000 # Runtime UID used by Dockerfile and compose user mapping
APP_GID=1000 # Runtime GID used by Dockerfile and compose user mapping

WEBHOOK_URL=http://${NETWORK_DOMAIN}/n8n/ # Public webhook URL used by n8n workflows
GENERIC_TIMEZONE=America/Sao_Paulo # Timezone used by n8n runtime
N8N_PATH=/n8n/ # Base path where n8n is served behind reverse proxy
N8N_EDITOR_BASE_URL=http://${NETWORK_DOMAIN}/n8n/ # Public URL for n8n editor UI
N8N_HOST=$NETWORK_DOMAIN # Public host used by n8n
N8N_PROTOCOL=http # Protocol used by n8n public URLs
N8N_LOG_LEVEL=debug # Log verbosity level used by n8n
N8N_SECURE_COOKIE=false # Enables/disables secure cookies (true recommended for HTTPS)
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true # Allows tool usage from n8n community packages
N8N_ACTIVATION_KEY=change-me # Activation key used by n8n license features