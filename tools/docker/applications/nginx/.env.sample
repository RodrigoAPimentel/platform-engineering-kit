######################################################
## Global ############################################
######################################################
PROJECT_NAME=nginx # Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=Nginx # Human-readable project name used in UI templates
APP_ENV=development # Runtime profile: development or production
IMAGE_NAME=nginx # Default image repository/name for app builds
IMAGE_VERSION=1.29.8 # Default image tag; use dev in local iterations
CONTAINER_NAME=nginx # Deterministic container name for local stacks
VOLUME_NAME=${PROJECT_NAME}-data # Global volume name used by compose volumes.*.name
TZ=America/Sao_Paulo # Container timezone
LANG=C.UTF-8 # Locale

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=custom-network # Network name used by compose networks.network.name
NETWORK_DRIVER=bridge # Network driver used by compose networks.network.driver
NETWORK_MTU=1500 # MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # compose driver_opts: bridge.enable_ip_masquerade
NETWORK_ENABLE_ICC=true # compose driver_opts: bridge.enable_icc
NETWORK_DOMAIN=localhost # Base domain used by reverse proxy/routes

######################################################
## App ###############################################
######################################################
APP_PORT=80 # App service port published by compose
APP_UID=10001 # Runtime UID used by Dockerfile and compose user mapping
APP_GID=10001 # Runtime GID used by Dockerfile and compose user mapping

######################################################
## Exporter ##########################################
######################################################
EXPORTER_IMAGE=nginx/nginx-prometheus-exporter # Docker image used for Nginx Prometheus Exporter
EXPORTER_VERSION=1.5 # Docker image tag used for Nginx Prometheus Exporter; use dev in local iterations
EXPORTER_PORT=9113 # Port exposed by the Nginx Exporter container
EXPORTER_CONTAINER_NAME=nginx-exporter # Deterministic container name for the Nginx Exporter
EXPORTER_UID=10001 # Runtime UID used by Dockerfile and compose user mapping
EXPORTER_GID=10001 # Runtime GID used by Dockerfile and compose user mapping
