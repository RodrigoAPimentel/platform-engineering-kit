######################################################
## Global ############################################
######################################################
PROJECT_NAME=waha # Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=Waha # Human-readable project name used in UI templates
APP_ENV=development # Runtime profile: development or production
IMAGE_NAME=devlikeapro/waha # Default image repository/name for app builds
IMAGE_VERSION=latest-2026.3.2 # Default image tag; use dev in local iterations
CONTAINER_NAME=waha # Deterministic container name for local stacks
VOLUME_NAME=${PROJECT_NAME}-data_sessions # Global volume name used by compose volumes.*.name
VOLUME_MEDIA_NAME=${PROJECT_NAME}-data_media # Global volume name used by compose volumes.*.name
TZ=America/Sao_Paulo # Container timezone
LANG=C.UTF-8 # Locale

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=custom-network # Network name used by compose networks.network.name
NETWORK_DRIVER=bridge # Network driver used by compose networks.network.driver
NETWORK_MTU=1500 # MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # compose driver_opts: bridge.enable_ip_masquerade
NETWORK_ENABLE_ICC=true # compose driver_opts: bridge.enable_icc
NETWORK_DOMAIN=localhost # Base domain used by reverse proxy/routes

######################################################
## App ###############################################
######################################################
APP_PORT=3002 # App service port published by compose
APP_UID=1000 # Runtime UID used by Dockerfile and compose user mapping
APP_GID=1000 # Runtime GID used by Dockerfile and compose user mapping

WAHA_WORKER_ID=WAHA # Worker identifier used by WAHA
WAHA_API_KEY=change-me # API key required to authenticate WAHA requests
WAHA_DASHBOARD_USERNAME=change-me # Username for WAHA dashboard access
WAHA_DASHBOARD_PASSWORD=change-me # Password for WAHA dashboard access
WAHA_DASHBOARD_ENABLED=True # Enables WAHA dashboard UI
WAHA_BIND_IP=0.0.0.0 # Network interface used by WAHA inside the container
WAHA_NAMESPACE=all # Default namespace used by WAHA
WAHA_BASE_URL=http://192.168.99.21/waha/ # Public base URL used by WAHA callbacks and links
WAHA_LOG_FORMAT=JSON # Log output format used by WAHA
WAHA_LOG_LEVEL=info # Log verbosity level used by WAHA
WAHA_PRINT_QR=False # Controls whether QR is printed in logs
WAHA_MEDIA_STORAGE=LOCAL # Storage backend used for WhatsApp media files
WHATSAPP_FILES_LIFETIME=0 # Lifetime in seconds for stored WhatsApp files (0 means no expiration)
WHATSAPP_FILES_FOLDER=/app/.media # Filesystem path where WhatsApp media files are stored
WHATSAPP_HOOK_URL=http://host.docker.internal:5678/webhook/webhook # Webhook endpoint that receives WAHA events
WHATSAPP_HOOK_EVENTS=message # WAHA event types forwarded to webhook
WHATSAPP_API_PORT=$APP_PORT # WAHA API port used by WhatsApp integrations
WHATSAPP_SWAGGER_USERNAME=$WAHA_DASHBOARD_USERNAME # Username used to access WAHA Swagger UI
WHATSAPP_SWAGGER_PASSWORD=$WAHA_DASHBOARD_PASSWORD # Password used to access WAHA Swagger UI
WHATSAPP_SWAGGER_ENABLED=True # Enables WAHA Swagger UI endpoint
WHATSAPP_DEFAULT_ENGINE=GOWS # Default WhatsApp engine used by WAHA