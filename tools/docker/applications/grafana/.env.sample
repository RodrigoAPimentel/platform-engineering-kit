######################################################
## Global ############################################
######################################################
PROJECT_NAME=grafana # Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=Grafana # Human-readable project name used in UI templates
APP_ENV=development # Runtime profile: development or production
IMAGE_NAME=grafana/grafana # Default image repository/name for app builds
IMAGE_VERSION=12.4 # Default image tag; use dev in local iterations
CONTAINER_NAME=grafana # Deterministic container name for local stacks
VOLUME_NAME=${PROJECT_NAME}-data # Global volume name used by compose volumes.*.name
TZ=America/Sao_Paulo # Container timezone
LANG=C.UTF-8 # Locale

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=custom-network # Network name used by compose networks.network.name
NETWORK_DRIVER=bridge # Network driver used by compose networks.network.driver
NETWORK_MTU=1500 # MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # compose driver_opts: bridge.enable_ip_masquerade
NETWORK_ENABLE_ICC=true # compose driver_opts: bridge.enable_icc
NETWORK_DOMAIN=jabutidom # Base domain used by reverse proxy/routes

######################################################
## App ###############################################
######################################################
APP_PORT=3001 # App service port published by compose
APP_UID=10001 # Runtime UID used by Dockerfile and compose user mapping
APP_GID=10001 # Runtime GID used by Dockerfile and compose user mapping
GF_SECURITY_ADMIN_USER=$PROJECT_NAME # Grafana admin username
GF_SECURITY_ADMIN_PASSWORD=change_me # Grafana admin password
GF_PLUGINS_PREINSTALL=grafana-clock-panel,grafana-simple-json-datasource # Grafana plugins installed on startup
GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s/grafana/ # Public Grafana URL when served behind reverse proxy
GF_SERVER_SERVE_FROM_SUB_PATH=true # Enables serving Grafana from a subpath