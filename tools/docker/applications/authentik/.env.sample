######################################################
## Global ############################################
######################################################
PROJECT_NAME=authentik # (string) Project identifier used in container/volume/network names
PROJECT_FORMATTED_NAME=Authentik # (string) Human-readable project name used in UI templates
APP_ENV=development # (string: development|production) Runtime profile
VOLUME_NAME=${PROJECT_NAME}-data # (string) Global volume name used by compose volumes.*.name
TZ=America/Sao_Paulo # (string) Container timezone (e.g., America/Sao_Paulo)
LANG=C.UTF-8 # (string) Locale (e.g., C.UTF-8)

######################################################
## Networking ########################################
######################################################
NETWORK_NAME=custom-network # (string) Docker network name used by compose
NETWORK_DRIVER=bridge # (string) Docker network driver (usually bridge)
NETWORK_MTU=1500 # (int) MTU used by compose networks.network.driver_opts
NETWORK_ENABLE_IP_MASQUERADE=true # (bool) Enable NAT (bridge.enable_ip_masquerade)
NETWORK_ENABLE_ICC=true # (bool) Enable inter-container communication (bridge.enable_icc)
NETWORK_DOMAIN=localhost # (string) Base domain used by reverse proxy/routes

######################################################
## Postgres ##########################################
######################################################
PG_IMAGE_NAME=docker.io/library/postgres # (string) Postgres image name
PG_CONTAINER_NAME=${PROJECT_NAME}_postgres # (string) Postgres container name
PG_IMAGE_VERSION=16-alpine # (string) Postgres image tag/version
PG_DB=authentik # (string) Database name
PG_USER=authentik # (string) Database user
# To generate a secure database password, run:
#   echo "PG_PASS=$(openssl rand -base64 36 | tr -d '\n')" >> .env
PG_PASS=change_me # (string) Database password

######################################################
## Server ############################################
######################################################
SERVER_IMAGE_NAME=ghcr.io/goauthentik/server # (string) Authentik server image name
SERVER_IMAGE_VERSION=2026.2.2 # (string) Authentik server image tag/version
# To generate a secure Authentik secret key, run:
#   echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 60 | tr -d '\n')" >> .env
AUTHENTIK_SECRET_KEY=change_me # (string) Authentik secret key (must be random and secret)
SERVER_PORT_HTTP=9000 # (int) Authentik HTTP port
SERVER_PORT_HTTPS=9443 # (int) Authentik HTTPS port
SERVER_CONTAINER_NAME=${PROJECT_NAME}_server # (string) Authentik server container name
AUTHENTIK_WEB__PATH=/authentik/ # (string) Base path when serving Authentik behind a reverse proxy subpath

######################################################
## Worker ############################################
######################################################
WORKER_IMAGE_NAME=ghcr.io/goauthentik/server # (string) Authentik worker image name
WORKER_IMAGE_VERSION=2026.2.2 # (string) Authentik worker image tag/version
WORKER_CONTAINER_NAME=${PROJECT_NAME}_worker # (string) Authentik worker container name